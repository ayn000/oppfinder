# ===== OppFinder — configuration =====
# Copie ce fichier en `.env` puis remplis les valeurs.

# En production derrière HTTPS (nginx + certbot) : true
COOKIE_SECURE=false

# Cadence de mise à jour des alertes (heures) et rétention des annonces (jours)
REFRESH_INTERVAL_HOURS=24
JOB_RETENTION_DAYS=7

# Score minimal (0-100) pour qu'une annonce soit conservée
MIN_SCORE=10

# ----- France Travail (fortement recommandé pour la France : offres + stages) -----
# Gratuit : https://francetravail.io — créer une application et souscrire à
# l'API "Offres d'emploi v2" pour obtenir ces identifiants.
FT_CLIENT_ID=
FT_CLIENT_SECRET=

# ----- Adzuna (recommandé : agrégateur France tous secteurs) -----
# Gratuit : https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ----- Assistant IA (optionnel) -----
# Clé sur https://console.anthropic.com — sans clé, le chat est simplement désactivé.
ANTHROPIC_API_KEY=
# Modèle par défaut : le plus intelligent. Pour réduire les coûts : claude-haiku-4-5
ANTHROPIC_MODEL=claude-opus-4-8
